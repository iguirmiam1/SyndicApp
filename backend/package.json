{
  "name": "syndicpro-backend",
  "version": "1.0.0",
  "description": "SyndicPro REST API — Gestion de copropriété",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:migrate": "node -e \"require('./db').query(require('fs').readFileSync('./schema.sql','utf8'))\"",
    "db:seed": "node -e \"require('./db').query(require('fs').readFileSync('./seed.sql','utf8'))\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
